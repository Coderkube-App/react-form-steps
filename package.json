{
  "name": "react-multistep-form",
  "version": "1.0.0",
  "description": "A production-ready multi-step form manager for React with persistence and edit mode support.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "react-native": "./dist/index.native.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "react-multistep-form": "./dist/cli.js"
  },
  "files": [
    "dist",
    "assets"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./dist/index.native.js",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./native": {
      "types": "./dist/index.native.d.ts",
      "import": "./dist/index.native.mjs",
      "require": "./dist/index.native.js"
    },
    "./types": {
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "react",
    "form",
    "multi-step",
    "wizard",
    "react-hook-form",
    "zod",
    "persistence",
    "draft"
  ],
  "author": "Antigravity",
  "license": "MIT",
  "dependencies": {
    "lodash.debounce": "^4.0.8",
    "lucide-react": "^0.363.0"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0",
    "react-hook-form": ">=7.0.0",
    "@hookform/resolvers": ">=3.0.0",
    "zod": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/lodash.debounce": "^4.0.9",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@types/react-native": "^0.72.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.2"
  },
  "overrides": {
    "@types/react": "^18.2.66"
  }
}
